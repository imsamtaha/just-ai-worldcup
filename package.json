    "@types/react-dom": "latest",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "latest",
    "eslint-plugin-react-hooks": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "typescript-eslint": "^8.62.0",
    "vitest": "latest",
    "wrangler": "latest",
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest"
  }
